# EcoAct Recommender v1.2 — API Keys
# Copy file ini menjadi .env dan isi dengan API key kamu

# OpenWeatherMap — daftar gratis di https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweathermap_key_here

# AirVisual / IQAir — daftar gratis di https://www.iqair.com/dashboard/api
AIRVISUAL_API_KEY=your_airvisual_key_here

# Catatan:
# - Tanpa API key, aplikasi tetap berjalan menggunakan mock data realistis
# - Free tier OpenWeatherMap: 1.000 request/hari
# - Free tier AirVisual: 10.000 request/bulan
